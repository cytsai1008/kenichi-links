---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import LinkButton from "../components/LinkButton.astro";
import ImgLinkButton from "../components/ImgLinkButton.astro";
import { siteConfig } from "../data/config";
---

<Layout>
  <div class="mx-auto my-auto w-screen">
    <div
      class="absolute z-0 my-auto grid min-h-full min-w-full place-content-center px-7 py-10"
    >
      <div class="absolute z-10 h-full min-w-full overflow-hidden bg-black">
        <Image
          src={siteConfig.coverImage}
          loading="eager"
          decoding="async"
          alt=""
          aria-hidden="true"
          class="h-full w-full scale-110 object-cover object-center blur-md"
        />
      </div>
      <div class="absolute z-20 h-full w-full bg-black opacity-60"></div>
      <div class="z-30 text-center">
        <Image
          id="image"
          class="relative z-50 m-auto w-1/2 rounded-lg shadow-2xl motion-reduce:transition-none sm:w-1/2 md:w-1/3 lg:w-1/5 xl:w-1/6 2xl:w-1/6"
          src={siteConfig.imageUrl}
          alt={siteConfig.name}
          loading="eager"
        />
        <br />
        <h1 class="relative z-20 mx-auto mt-3 text-center text-5xl font-semibold">
          {siteConfig.name}
        </h1>
        <hr class="relative z-20 my-2 opacity-25" />
        <p
          class="relative z-20 mx-auto mt-1.5 inline-flex justify-center overflow-visible text-center text-lg font-light break-keep opacity-70 sm:w-full md:w-7/12 xl:w-5/12 2xl:w-5/12"
          set:html={siteConfig.tagline}
        />
        <div
          class="mx-auto my-7 grid w-full max-w-xl grid-cols-1 gap-x-4 md:grid-cols-2 lg:max-w-5xl lg:auto-cols-fr lg:grid-flow-col"
        >
          {
            siteConfig.links.length > 0 &&
              siteConfig.links.map((link) => <LinkButton link={link} />)
          }
          {
            siteConfig.imgLinks.length > 0 &&
              siteConfig.imgLinks.map((link) => <ImgLinkButton link={link} />)
          }
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import gsap from "gsap";

  const img = document.getElementById("image") as HTMLImageElement | null;
  if (img) {
    let isDragging = false;
    let startCursorX = 0,
      startCursorY = 0;
    let startGsapX = 0,
      startGsapY = 0;

    img.style.cursor = "default";
    img.draggable = false;

    img.addEventListener("mousedown", function (e) {
      isDragging = true;
      startCursorX = e.clientX;
      startCursorY = e.clientY;
      startGsapX = parseFloat(gsap.getProperty(img, "x") as string) || 0;
      startGsapY = parseFloat(gsap.getProperty(img, "y") as string) || 0;
      gsap.killTweensOf(img);
      img.style.cursor = "default";
      e.preventDefault();
    });

    img.addEventListener(
      "touchstart",
      function (e) {
        isDragging = true;
        startCursorX = e.touches[0].clientX;
        startCursorY = e.touches[0].clientY;
        startGsapX = parseFloat(gsap.getProperty(img, "x") as string) || 0;
        startGsapY = parseFloat(gsap.getProperty(img, "y") as string) || 0;
        gsap.killTweensOf(img);
        e.preventDefault();
      },
      { passive: false }
    );

    window.addEventListener("mousemove", function (e) {
      if (!isDragging) return;
      gsap.set(img, {
        x: startGsapX + (e.clientX - startCursorX),
        y: startGsapY + (e.clientY - startCursorY),
      });
    });

    window.addEventListener(
      "touchmove",
      function (e) {
        if (!isDragging) return;
        gsap.set(img, {
          x: startGsapX + (e.touches[0].clientX - startCursorX),
          y: startGsapY + (e.touches[0].clientY - startCursorY),
        });
      },
      { passive: false }
    );

    window.addEventListener("mouseup", function () {
      if (!isDragging) return;
      isDragging = false;
      img.style.cursor = "default";
      gsap.to(img, { duration: 1, x: 0, y: 0, ease: "elastic.out(1, 0.4)" });
    });

    window.addEventListener("touchend", function () {
      if (!isDragging) return;
      isDragging = false;
      gsap.to(img, { duration: 1, x: 0, y: 0, ease: "elastic.out(1, 0.4)" });
    });
  }
</script>
