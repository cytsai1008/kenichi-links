---
import type { Link } from "../data/config";

interface Props {
  link: Link;
}

const { link } = Astro.props;
const href = link.username ? `${link.url.replace(/\/$/, "")}/${link.username}` : link.url;
const hasColor = !!link.color;
const spanStyle = hasColor ? `--link-bg: ${link.color}; --link-shadow: ${link.color}80;` : "";
const textStyle = link.textColor ? `color: ${link.textColor};` : "";
---

<a class="link-anchor" href={href} target="_blank" rel="noopener noreferrer" aria-label={link.name}>
  <span
    class:list={[
      "links",
      hasColor
        ? "bg-(--link-bg) shadow-[0px_10px_25px_0px_var(--link-shadow)]"
        : "border-[0.1rem] border-white shadow-[0px_10px_25px_0px_#ffffff80]",
    ]}
    style={spanStyle}
  >
    <span class="flex items-center justify-center" style={textStyle}>
      <i class={`${link.iconClass} align-middle`} aria-hidden="true"></i>
      <span class="mx-1.5 align-middle font-normal">{link.name}</span>
    </span>
  </span>
</a>
