{
  "name": "links",
  "version": "1.0.0",
  "description": "A Beautiful Jekyll Theme For Links",
  "main": "postcss.config.js",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "puppeteer": "^24.39.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@shopify/prettier-plugin-liquid": "^1.10.0",
    "@tailwindcss/cli": "^4.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-html": "^8.1.4",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./_tailwind/input.css -o ./assets/css/main.css --minify",
    "watch:css": "tailwindcss -i ./_tailwind/input.css -o ./assets/css/main.css --watch",
    "serve": "npm run build:css && bundle exec jekyll serve",
    "ss": "node ./scripts/screenshot.js",
    "check:config": "node ./scripts/validate-config.js",
    "check:templates": "node ./scripts/lint-templates.js",
    "check": "npm run check:config && npm run check:templates",
    "lint": "eslint \"scripts/**/*.js\" \"_layouts/**/*.html\" \"_includes/**/*.html\"",
    "format": "prettier --write \"**/*.{html,css,js,json,md,yml}\""
  },
  "keywords": [
    "links",
    "jekyll"
  ],
  "author": "CYTsai",
  "license": "MIT"
}
